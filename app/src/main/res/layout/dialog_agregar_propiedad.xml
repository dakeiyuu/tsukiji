<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#FFFFFF"
    android:clipToPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="24dp">

        <!-- Handle del BottomSheet -->
        <View
            android:layout_width="36dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="4dp"
            android:background="#DDDDDD" />

        <!-- ── HEADER ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:paddingEnd="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Agregar propiedad"
                android:textColor="#F5732A"
                android:textSize="22sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium" />

            <!-- Botón cerrar -->
            <ImageView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                android:tint="#BBBBBB"
                android:background="@drawable/bg_close_circle"
                android:padding="8dp"
                android:contentDescription="Cerrar" />

        </LinearLayout>

        <!-- Divisor -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:background="#F0F0F0"
            android:layout_marginBottom="20dp" />

        <!-- ── Tipo de operación ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tipo de operación"
            android:textColor="#1A1A1A"
            android:textSize="14sp"
            android:textStyle="bold"
            android:paddingStart="20dp"
            android:layout_marginBottom="10dp" />

        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/toggle_tipo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginBottom="24dp"
            app:singleSelection="true"
            app:selectionRequired="true">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_venta"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:text="Venta"
                android:textColor="#F5732A"
                android:textSize="15sp"
                android:textStyle="bold"
                app:icon="@android:drawable/ic_menu_sort_by_size"
                app:iconGravity="start"
                app:iconTint="#F5732A"
                app:strokeColor="#F5732A"
                app:strokeWidth="1.5dp"
                app:cornerRadius="12dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_renta"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:text="Renta"
                android:textColor="#AAAAAA"
                android:textSize="15sp"
                android:textStyle="bold"
                app:icon="@android:drawable/ic_menu_myplaces"
                app:iconGravity="start"
                app:iconTint="#AAAAAA"
                app:strokeColor="#E0E0E0"
                app:strokeWidth="1.5dp"
                app:cornerRadius="12dp" />

        </com.google.android.material.button.MaterialButtonToggleGroup>

        <!-- ── Nombre ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nombre o título *"
            android:textColor="#1A1A1A"
            android:textSize="14sp"
            android:textStyle="bold"
            android:paddingStart="20dp"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginBottom="20dp"
            app:boxStrokeColor="#F5732A"
            app:boxStrokeWidth="1.5dp"
            app:boxStrokeWidthFocused="1.5dp"
            app:hintEnabled="false"
            app:startIconDrawable="@android:drawable/ic_menu_myplaces"
            app:startIconTint="#F5732A"
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_nombre"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:hint="Ej. Local Comercial Centro"
                android:textColor="#1A1A1A"
                android:textColorHint="#CCCCCC"
                android:textSize="14sp"
                android:inputType="textCapWords" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- ── Dirección ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:layout_marginBottom="8dp">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@android:drawable/ic_menu_mylocation"
                android:tint="#F5732A"
                android:layout_marginEnd="6dp"
                android:contentDescription="Dirección" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Dirección"
                android:textColor="#1A1A1A"
                android:textSize="14sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Fila: Calle + Número exterior -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginBottom="10dp">

            <!-- Calle -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:layout_marginEnd="8dp"
                app:boxStrokeColor="#F5732A"
                app:boxStrokeWidth="1.5dp"
                app:boxStrokeWidthFocused="1.5dp"
                app:hintEnabled="false"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_calle"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:hint="Calle *"
                    android:textColor="#1A1A1A"
                    android:textColorHint="#CCCCCC"
                    android:textSize="13sp"
                    android:inputType="textCapWords" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Número exterior -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                app:boxStrokeColor="#F5732A"
                app:boxStrokeWidth="1.5dp"
                app:boxStrokeWidthFocused="1.5dp"
                app:hintEnabled="false"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_num_ext"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:hint="No. ext."
                    android:textColor="#1A1A1A"
                    android:textColorHint="#CCCCCC"
                    android:textSize="13sp"
                    android:inputType="textCapCharacters" />

            </com.google.android.material.textfield.TextInputLayout>

        </LinearLayout>

        <!-- Número interior (opcional) -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginBottom="10dp"
            app:boxStrokeColor="#F5732A"
            app:boxStrokeWidth="1.5dp"
            app:boxStrokeWidthFocused="1.5dp"
            app:hintEnabled="false"
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_num_int"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:hint="Número interior / Depto. (opcional)"
                android:textColor="#1A1A1A"
                android:textColorHint="#CCCCCC"
                android:textSize="13sp"
                android:inputType="textCapCharacters" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Colonia -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginBottom="10dp"
            app:boxStrokeColor="#F5732A"
            app:boxStrokeWidth="1.5dp"
            app:boxStrokeWidthFocused="1.5dp"
            app:hintEnabled="false"
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_colonia"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:hint="Colonia *"
                android:textColor="#1A1A1A"
                android:textColorHint="#CCCCCC"
                android:textSize="13sp"
                android:inputType="textCapWords" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Fila: Ciudad + Estado -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginBottom="10dp">

            <!-- Ciudad -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                app:boxStrokeColor="#F5732A"
                app:boxStrokeWidth="1.5dp"
                app:boxStrokeWidthFocused="1.5dp"
                app:hintEnabled="false"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_ciudad"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:hint="Ciudad *"
                    android:textColor="#1A1A1A"
                    android:textColorHint="#CCCCCC"
                    android:textSize="13sp"
                    android:inputType="textCapWords" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Estado -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                app:boxStrokeColor="#F5732A"
                app:boxStrokeWidth="1.5dp"
                app:boxStrokeWidthFocused="1.5dp"
                app:hintEnabled="false"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_estado"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:hint="Estado *"
                    android:textColor="#1A1A1A"
                    android:textColorHint="#CCCCCC"
                    android:textSize="13sp"
                    android:inputType="textCapWords" />

            </com.google.android.material.textfield.TextInputLayout>

        </LinearLayout>

        <!-- País -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginBottom="20dp"
            app:boxStrokeColor="#F5732A"
            app:boxStrokeWidth="1.5dp"
            app:boxStrokeWidthFocused="1.5dp"
            app:hintEnabled="false"
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_pais"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:hint="País *"
                android:text="México"
                android:textColor="#1A1A1A"
                android:textColorHint="#CCCCCC"
                android:textSize="13sp"
                android:inputType="textCapWords" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- ── Precio ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Precio (MXN) *"
            android:textColor="#1A1A1A"
            android:textSize="14sp"
            android:textStyle="bold"
            android:paddingStart="20dp"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginBottom="24dp"
            app:boxStrokeColor="#F5732A"
            app:boxStrokeWidth="1.5dp"
            app:boxStrokeWidthFocused="1.5dp"
            app:hintEnabled="false"
            app:startIconDrawable="@android:drawable/ic_menu_compass"
            app:startIconTint="#F5732A"
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_precio"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:hint="Ej. 15000"
                android:textColor="#1A1A1A"
                android:textColorHint="#CCCCCC"
                android:textSize="14sp"
                android:inputType="numberDecimal" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- ── Fotos ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Fotos (máx. 4)"
            android:textColor="#1A1A1A"
            android:textSize="14sp"
            android:textStyle="bold"
            android:paddingStart="20dp"
            android:layout_marginBottom="12dp" />

        <!-- Grid 2x2 -->
        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginBottom="24dp"
            android:columnCount="2"
            android:rowCount="2"
            android:useDefaultMargins="false">

            <!-- Foto 1 -->
            <FrameLayout
                android:id="@+id/frame_foto_1"
                android:layout_width="0dp"
                android:layout_height="130dp"
                android:layout_columnWeight="1"
                android:layout_rowWeight="1"
                android:layout_margin="5dp"
                android:background="@drawable/bg_photo_slot"
                android:foreground="?attr/selectableItemBackground">

                <ImageView
                    android:id="@+id/iv_foto_1"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:visibility="gone" />

                <LinearLayout
                    android:id="@+id/placeholder_1"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center">

                    <FrameLayout
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_camera_circle">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@android:drawable/ic_menu_camera"
                            android:tint="#F5732A"
                            android:layout_gravity="center" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Agregar foto"
                        android:textColor="#BBBBBB"
                        android:textSize="12sp"
                        android:layout_marginTop="8dp" />

                </LinearLayout>

                <ImageView
                    android:id="@+id/btn_remove_1"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="top|end"
                    android:layout_margin="6dp"
                    android:src="@android:drawable/ic_menu_close_clear_cancel"
                    android:tint="#FFFFFF"
                    android:background="@drawable/bg_remove_btn"
                    android:visibility="gone"
                    android:padding="4dp"
                    android:contentDescription="Eliminar foto" />

            </FrameLayout>

            <!-- Foto 2 -->
            <FrameLayout
                android:id="@+id/frame_foto_2"
                android:layout_width="0dp"
                android:layout_height="130dp"
                android:layout_columnWeight="1"
                android:layout_rowWeight="1"
                android:layout_margin="5dp"
                android:background="@drawable/bg_photo_slot"
                android:foreground="?attr/selectableItemBackground">

                <ImageView
                    android:id="@+id/iv_foto_2"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:visibility="gone" />

                <LinearLayout
                    android:id="@+id/placeholder_2"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center">

                    <FrameLayout
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_camera_circle">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@android:drawable/ic_menu_camera"
                            android:tint="#F5732A"
                            android:layout_gravity="center" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Agregar foto"
                        android:textColor="#BBBBBB"
                        android:textSize="12sp"
                        android:layout_marginTop="8dp" />

                </LinearLayout>

                <ImageView
                    android:id="@+id/btn_remove_2"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="top|end"
                    android:layout_margin="6dp"
                    android:src="@android:drawable/ic_menu_close_clear_cancel"
                    android:tint="#FFFFFF"
                    android:background="@drawable/bg_remove_btn"
                    android:visibility="gone"
                    android:padding="4dp"
                    android:contentDescription="Eliminar foto" />

            </FrameLayout>

            <!-- Foto 3 -->
            <FrameLayout
                android:id="@+id/frame_foto_3"
                android:layout_width="0dp"
                android:layout_height="130dp"
                android:layout_columnWeight="1"
                android:layout_rowWeight="1"
                android:layout_margin="5dp"
                android:background="@drawable/bg_photo_slot"
                android:foreground="?attr/selectableItemBackground">

                <ImageView
                    android:id="@+id/iv_foto_3"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:visibility="gone" />

                <LinearLayout
                    android:id="@+id/placeholder_3"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center">

                    <FrameLayout
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_camera_circle">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@android:drawable/ic_menu_camera"
                            android:tint="#F5732A"
                            android:layout_gravity="center" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Agregar foto"
                        android:textColor="#BBBBBB"
                        android:textSize="12sp"
                        android:layout_marginTop="8dp" />

                </LinearLayout>

                <ImageView
                    android:id="@+id/btn_remove_3"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="top|end"
                    android:layout_margin="6dp"
                    android:src="@android:drawable/ic_menu_close_clear_cancel"
                    android:tint="#FFFFFF"
                    android:background="@drawable/bg_remove_btn"
                    android:visibility="gone"
                    android:padding="4dp"
                    android:contentDescription="Eliminar foto" />

            </FrameLayout>

            <!-- Foto 4 -->
            <FrameLayout
                android:id="@+id/frame_foto_4"
                android:layout_width="0dp"
                android:layout_height="130dp"
                android:layout_columnWeight="1"
                android:layout_rowWeight="1"
                android:layout_margin="5dp"
                android:background="@drawable/bg_photo_slot"
                android:foreground="?attr/selectableItemBackground">

                <ImageView
                    android:id="@+id/iv_foto_4"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:visibility="gone" />

                <LinearLayout
                    android:id="@+id/placeholder_4"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center">

                    <FrameLayout
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_camera_circle">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@android:drawable/ic_menu_camera"
                            android:tint="#F5732A"
                            android:layout_gravity="center" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Agregar foto"
                        android:textColor="#BBBBBB"
                        android:textSize="12sp"
                        android:layout_marginTop="8dp" />

                </LinearLayout>

                <ImageView
                    android:id="@+id/btn_remove_4"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="top|end"
                    android:layout_margin="6dp"
                    android:src="@android:drawable/ic_menu_close_clear_cancel"
                    android:tint="#FFFFFF"
                    android:background="@drawable/bg_remove_btn"
                    android:visibility="gone"
                    android:padding="4dp"
                    android:contentDescription="Eliminar foto" />

            </FrameLayout>

        </GridLayout>

        <!-- ── Botón publicar ── -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_publicar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:text="PUBLICAR PROPIEDAD"
            android:textColor="#FFFFFF"
